<UserControl x:Class="CSIModellingTools.Controls.SliderNumberInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinHeight="34">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="145"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="74"/>
            <ColumnDefinition Width="42"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Label, ElementName=Root}"
                   Margin="0,7,10,3"
                   Foreground="#475569"
                   FontWeight="Normal"
                   TextWrapping="Wrap"/>
        <Slider Grid.Column="1"
                Minimum="{Binding Minimum, ElementName=Root}"
                Maximum="{Binding Maximum, ElementName=Root}"
                SmallChange="{Binding SmallChange, ElementName=Root}"
                LargeChange="{Binding LargeChange, ElementName=Root}"
                TickFrequency="{Binding SmallChange, ElementName=Root}"
                IsSnapToTickEnabled="True"
                Value="{Binding Value, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center"
                Margin="0,0,8,0"/>
        <TextBox x:Name="ValueBox"
                 Grid.Column="2"
                 Text="{Binding ValueText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                 TextChanged="ValueBox_TextChanged"
                 MinWidth="0"/>
        <TextBlock Grid.Column="3"
                   Text="{Binding Unit, ElementName=Root}"
                   Margin="8,7,0,3"
                   Foreground="#475569"
                   FontWeight="Normal"/>
    </Grid>
</UserControl>

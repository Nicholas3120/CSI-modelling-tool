<UserControl x:Class="CSIModellingTools.Views.ModelCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#1f2937"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinWidth" Value="90"/>
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_ConfirmOnEnter"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="MinWidth" Value="180"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,7,10,3"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,7,0,3"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Resources>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" MinHeight="72"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="*" MinHeight="200"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Comparison Sources" Grid.Row="0">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Button DockPanel.Dock="Left"
                                        Content="⟳ Refresh instances"
                                        Command="{Binding RefreshEtabsInstancesCommand}"/>
                                <Menu DockPanel.Dock="Right" Background="Transparent" VerticalAlignment="Center">
                                    <MenuItem Header="⋯ Tools">
                                        <MenuItem Header="Assign Member IDs…"
                                                  Command="{Binding AssignMemberIdsCommand}"
                                                  ToolTip="Stamp a persistent tracking ID into each frame and area that lacks one, so members track across revisions even if renamed or moved. Unlocks the model; save afterwards."/>
                                    </MenuItem>
                                </Menu>
                                <TextBlock Text="{Binding ConnectionStatus, StringFormat=Status: {0}}"
                                           Foreground="#64748b"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                            </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                            <!-- Base source card -->
                            <Border Grid.Column="0" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Base model (old)" FontWeight="Bold" Foreground="#0f172a"/>
                                    <TextBlock Text="Pick the open ETABS model to use as the baseline." Foreground="#64748b" FontSize="11" Margin="0,2,0,4" TextWrapping="Wrap"/>
                                    <ComboBox ItemsSource="{Binding EtabsInstances}" SelectedItem="{Binding BaseInstance}" DisplayMemberPath="DisplayName"/>
                                </StackPanel>
                            </Border>

                            <!-- Compare source card -->
                            <Border Grid.Column="1" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Compare model (new)" FontWeight="Bold" Foreground="#0f172a"/>
                                    <TextBlock Text="Pick the open ETABS model to compare against the baseline." Foreground="#64748b" FontSize="11" Margin="0,2,0,4" TextWrapping="Wrap"/>
                                    <ComboBox ItemsSource="{Binding EtabsInstances}" SelectedItem="{Binding CompareInstance}" DisplayMemberPath="DisplayName"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                <Button Content="Compare"
                                        Command="{Binding RunComparisonCommand}"
                                        MinWidth="130"
                                        MinHeight="48"
                                        FontWeight="Bold"
                                        FontSize="14"
                                        Background="#2563eb"
                                        Foreground="White"
                                        ToolTip="Read both open ETABS models and compare them"/>
                                <ProgressBar Height="10"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding ProgressPercent, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                                             Margin="0,6,0,0"
                                             Visibility="{Binding BusyVisibility}"/>
                                <TextBlock Text="{Binding ProgressText}"
                                           Foreground="#475569"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"
                                           Visibility="{Binding BusyVisibility}"/>
                                <Button Content="Cancel"
                                        Command="{Binding CancelCommand}"
                                        Margin="0,4,0,0"
                                        Visibility="{Binding BusyVisibility}"/>
                            </StackPanel>
                            </Grid>
                        </DockPanel>
                    </GroupBox>

                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Background="#CBD5E1"
                                  Cursor="SizeNS"/>

                    <GroupBox Header="Comparison Results" Grid.Row="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250" MinWidth="190"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*" MinWidth="320"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="340" MinWidth="220"/>
                            </Grid.ColumnDefinitions>

                            <!-- Project Explorer: summary strip + category tree -->
                            <DockPanel Grid.Column="0" Margin="0,0,4,0">
                                <Border DockPanel.Dock="Top" Background="#f1f5f9" Padding="8" Margin="0,0,0,6" CornerRadius="4">
                                    <UniformGrid Columns="2" Rows="2">
                                        <TextBlock Text="{Binding TotalAdded, StringFormat=+{0} added}" Foreground="#16a34a" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TotalModified, StringFormat=~{0} modified}" Foreground="#d97706" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TotalRemoved, StringFormat=-{0} removed}" Foreground="#dc2626" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TotalUnchanged, StringFormat=Unchanged {0}}" Foreground="#64748b"/>
                                    </UniformGrid>
                                </Border>
                                <TextBlock DockPanel.Dock="Top" Text="PROJECT EXPLORER" FontWeight="Bold" Foreground="#475569" Margin="2,0,0,4"/>
                                <ListBox ItemsSource="{Binding Categories}"
                                         SelectedItem="{Binding SelectedCategoryNode}"
                                         BorderThickness="0"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding AddedText}" Foreground="#16a34a" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding RemovedText}" Foreground="#dc2626" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding ModifiedText}" Foreground="#d97706" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding TotalText}" Foreground="#94a3b8"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#e2e8f0"/>

                            <!-- Results list (filters + grid) -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <WrapPanel Margin="0,0,0,8">
                                <TextBlock Text="Change" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Width="105"
                                          ItemsSource="{Binding ChangeTypeFilterOptions}"
                                          SelectedItem="{Binding SelectedChangeTypeFilter}"
                                          Margin="0,0,12,4"/>
                                <TextBlock Text="Object" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Width="120"
                                          ItemsSource="{Binding ObjectTypeFilterOptions}"
                                          SelectedItem="{Binding SelectedObjectTypeFilter}"
                                          Margin="0,0,12,4"/>
                                <TextBlock Text="Member" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Width="95"
                                          ItemsSource="{Binding MemberTypeFilterOptions}"
                                          SelectedItem="{Binding SelectedMemberTypeFilter}"
                                          Margin="0,0,12,4"/>
                                <TextBlock Text="Story" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Width="120"
                                          ItemsSource="{Binding StoryFilterOptions}"
                                          SelectedItem="{Binding SelectedStoryFilter}"
                                          Margin="0,0,12,4"/>
                                <TextBlock Text="Confidence" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Width="95"
                                          ItemsSource="{Binding ConfidenceFilterOptions}"
                                          SelectedItem="{Binding SelectedConfidenceFilter}"
                                          Margin="0,0,12,4"/>
                                <TextBox Width="200"
                                         Text="{Binding ResultSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Search object, section, material, story, or summary"
                                         Margin="0,0,12,4"/>
                                <CheckBox Content="Hide reviewed/ignored"
                                          IsChecked="{Binding HideReviewedAndIgnored}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,4"/>
                                <Button Content="Select highlighted"
                                        Command="{Binding SelectHighlightedResultsInEtabsCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=ModelCompareResultsGrid}"
                                        ToolTip="Select highlighted frame and area objects in the connected ETABS model"
                                        Margin="0,0,12,4"/>
                                <TextBlock Text="{Binding FilteredResultCount, StringFormat=Showing: {0}}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                            <DataGrid x:Name="ModelCompareResultsGrid"
                                      Grid.Row="1"
                                      ItemsSource="{Binding FilteredResults}"
                                      SelectedItem="{Binding SelectedObjectResult}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      CanUserAddRows="False"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      HorizontalScrollBarVisibility="Auto"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      RowDetailsVisibilityMode="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Change" Binding="{Binding PrimaryChangeType}" Width="80" MinWidth="70" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding ObjectTypeText}" Width="105" MinWidth="90" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Member" Binding="{Binding MemberTypeText}" Width="90" MinWidth="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Story" Binding="{Binding Story}" Width="95" MinWidth="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="What changed" Binding="{Binding ChangeSummary}" Width="*" MinWidth="240" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="ToolTip" Value="{Binding TraceText}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Severity" Binding="{Binding Importance}" Width="85" MinWidth="70" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Confidence" Binding="{Binding ConfidenceLevel}" Width="95" MinWidth="80" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="ETABS" Width="90" MinWidth="85">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Select"
                                                        Command="{Binding DataContext.SelectResultObjectInEtabsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Select this frame or area in the connected ETABS model"
                                                        Margin="2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Review" Width="130" MinWidth="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.ReviewStatusOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          SelectedItem="{Binding ReviewStatusText, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </Grid>

                            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#e2e8f0"/>

                            <!-- Detail: base-vs-compare for the highlighted object -->
                            <DockPanel Grid.Column="4" Margin="4,0,0,0">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedObjectResult.DisplayName}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedObjectResult.ObjectTypeText}" Foreground="#64748b" Margin="0,2,0,6"/>
                                <DataGrid ItemsSource="{Binding SelectedObjectRows}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Change" Binding="{Binding ChangeType}" Width="Auto"/>
                                        <DataGridTextColumn Header="Property" Binding="{Binding FieldName}" Width="*"/>
                                        <DataGridTextColumn Header="Base (old)" Binding="{Binding OldValue}" Width="*"/>
                                        <DataGridTextColumn Header="Compare (new)" Binding="{Binding NewValue}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Grid>
                    </GroupBox>

                    <DockPanel Grid.Row="3" Margin="0,6,0,0">
                        <Expander DockPanel.Dock="Right" Header="Messages" ExpandDirection="Up" HorizontalAlignment="Right">
                            <DataGrid ItemsSource="{Binding Messages}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      MaxHeight="180"
                                      MinWidth="520">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Severity" Binding="{Binding SeverityText}" Width="95"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>
                        <TextBlock Text="{Binding OperationStatus}"
                                   Foreground="#475569"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                </Grid>
</UserControl>

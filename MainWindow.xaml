<Window x:Class="CSIModellingTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:CSIModellingTools.Controls"
        xmlns:views="clr-namespace:CSIModellingTools.Views"
        mc:Ignorable="d"
        Title="CSI Modelling Tools" Height="860" Width="1320"
        MinHeight="760" MinWidth="1180"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#1f2937"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinWidth" Value="90"/>
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_ConfirmOnEnter"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="MinWidth" Value="180"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,7,10,3"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,7,0,3"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <DockPanel Background="#eef2f7">
        <TabControl Margin="12">
            <TabItem Header="ETABS Parametric Modelling">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="185"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="ETABS Connection" Grid.Row="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Button Content="Refresh ETABS Instances"
                                        Command="{Binding RefreshEtabsInstancesCommand}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding EtabsInstances}"
                                      SelectedItem="{Binding SelectedEtabsInstance}"
                                      DisplayMemberPath="DisplayName"/>
                            <Button Grid.Column="2"
                                    Content="Read ETABS Data"
                                    Command="{Binding ReadEtabsDataCommand}"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding ConnectionStatus, StringFormat=Status: {0}}"
                                       FontWeight="SemiBold"
                                       Foreground="#075985"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </GroupBox>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <GroupBox Header="Parameters">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="145"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Truss ID"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TrussId, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Truss type"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  ItemsSource="{Binding TrussTypes}"
                                                  SelectedItem="{Binding SelectedTrussType}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Insertion"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <CheckBox Grid.Row="2" Grid.Column="1"
                                                  Content="Selected ETABS points"
                                                  IsChecked="{Binding UseSelectedInsertionPoints}"
                                                  VerticalAlignment="Center"
                                                  Visibility="{Binding StandardTrussInputsVisibility}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Point pair"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <DockPanel Grid.Row="3" Grid.Column="1"
                                                   Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Button DockPanel.Dock="Right"
                                                    Content="Read Selected Points"
                                                    Command="{Binding ReadSelectedPointsCommand}"
                                                    Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding SelectedInsertionSummary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{StaticResource FieldValue}"/>
                                        </DockPanel>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Span"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <Grid Grid.Row="4" Grid.Column="1"
                                              Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding ManualSpan, UpdateSourceTrigger=LostFocus, StringFormat=0.##}"
                                                     IsEnabled="{Binding IsManualSpanEnabled}"/>
                                            <Slider Grid.Column="1" Minimum="0.5" Maximum="60" TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="1"
                                                    IsSnapToTickEnabled="True"
                                                    IsEnabled="{Binding IsManualSpanEnabled}"
                                                    Value="{Binding ManualSpan, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="10,0,0,0"/>
                                        </Grid>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Height"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <Grid Grid.Row="5" Grid.Column="1"
                                              Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding Height, UpdateSourceTrigger=LostFocus, StringFormat=0.##}"/>
                                            <Slider Grid.Column="1" Minimum="0.5" Maximum="12" TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="1"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="10,0,0,0"/>
                                        </Grid>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Panel count"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <Grid Grid.Row="6" Grid.Column="1"
                                              Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding PanelCount, UpdateSourceTrigger=LostFocus}"/>
                                            <Slider Grid.Column="1" Minimum="2" Maximum="30" TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding PanelCount, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="10,0,0,0"/>
                                        </Grid>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Top chord slope"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <Grid Grid.Row="7" Grid.Column="1"
                                              Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding RoofSlopePercent, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding SlopeModes}"
                                                      SelectedItem="{Binding SelectedTopChordSlopeMode}"
                                                      MinWidth="0"
                                                      Margin="8,3,0,3"/>
                                            <Slider Grid.Column="2" Minimum="-20" Maximum="20" TickFrequency="1"
                                                    Value="{Binding RoofSlopePercent, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="10,0,0,0"/>
                                        </Grid>

                                        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bottom chord slope"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <Grid Grid.Row="8" Grid.Column="1"
                                              Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding BottomChordSlopePercent, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding SlopeModes}"
                                                      SelectedItem="{Binding SelectedBottomChordSlopeMode}"
                                                      MinWidth="0"
                                                      Margin="8,3,0,3"/>
                                            <Slider Grid.Column="2" Minimum="-20" Maximum="20" TickFrequency="1"
                                                    Value="{Binding BottomChordSlopePercent, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="10,0,0,0"/>
                                        </Grid>

                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Orientation"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <Grid Grid.Row="9" Grid.Column="1"
                                              Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="145"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding TrussOrientationOptions}"
                                                      SelectedItem="{Binding SelectedTrussOrientation}"/>
                                            <TextBox Grid.Column="1"
                                                     Margin="8,0,0,0"
                                                     Text="{Binding TrussAngleDegrees, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                     IsEnabled="{Binding IsAngleInputEnabled}"/>
                                            <TextBlock Grid.Column="2" Text="deg" Style="{StaticResource FieldLabel}" Margin="6,7,0,3"/>
                                        </Grid>

                                        <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bottom-left X/Y"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <Grid Grid.Row="10" Grid.Column="1"
                                              Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="72"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="X" Style="{StaticResource FieldLabel}" Margin="0,7,4,3"/>
                                            <TextBox Grid.Column="1" Text="{Binding TrussBaseX, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                            <TextBlock Grid.Column="2" Text="Y" Style="{StaticResource FieldLabel}" Margin="8,7,4,3"/>
                                            <TextBox Grid.Column="3" Text="{Binding TrussBaseY, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                        </Grid>

                                        <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Top Z"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <Grid Grid.Row="11" Grid.Column="1"
                                              Visibility="{Binding StandardTrussInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="74"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding TrussZReferenceOptions}"
                                                      SelectedItem="{Binding SelectedTrussZReference}"
                                                      MinWidth="0"/>
                                            <TextBox Grid.Column="1"
                                                     Margin="8,0,0,0"
                                                     Text="{Binding TrussTopZ, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                            <ComboBox Grid.Column="2"
                                                      Margin="8,0,0,0"
                                                      ItemsSource="{Binding Stories}"
                                                      SelectedItem="{Binding SelectedTrussStory}"
                                                      IsEnabled="{Binding IsStoryZEnabled}"
                                                      MinWidth="0"/>
                                        </Grid>

                                        <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Preview colour"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <ComboBox Grid.Row="12" Grid.Column="1"
                                                  ItemsSource="{Binding PreviewColorOptions}"
                                                  SelectedItem="{Binding SelectedPreviewColor}"
                                                  Visibility="{Binding StandardTrussInputsVisibility}"/>

                                        <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Truss Spacing (to define number of truss)"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <TextBox Grid.Row="13" Grid.Column="1"
                                                 Text="{Binding TrussSpacing, UpdateSourceTrigger=LostFocus}"
                                                 Visibility="{Binding StandardTrussInputsVisibility}"/>

                                        <TextBlock Grid.Row="14" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Spacing offset direction"
                                                   Visibility="{Binding StandardTrussInputsVisibility}"/>
                                        <ComboBox Grid.Row="14" Grid.Column="1"
                                                  ItemsSource="{Binding TrussSpacingOffsetDirectionOptions}"
                                                  SelectedItem="{Binding SelectedTrussSpacingOffsetDirection}"
                                                  Visibility="{Binding StandardTrussInputsVisibility}"/>

                                        <TextBlock Grid.Row="15" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Generated"/>
                                        <TextBlock Grid.Row="15" Grid.Column="1" Style="{StaticResource FieldValue}" Text="{Binding GeneratedCountDisplay}"/>

                                        <TextBlock Grid.Row="16" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Group"/>
                                        <TextBox Grid.Row="16" Grid.Column="1" Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Truss Parameters" Visibility="{Binding StandardTrussInputsVisibility}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="150"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="+" Width="34" Command="{Binding AddTrussParameterCommand}"/>
                                            <Button Content="Copy" Command="{Binding CopyTrussParameterCommand}" Margin="6,0,0,0"/>
                                            <Button Content="-" Width="34" Command="{Binding RemoveTrussParameterCommand}" Margin="6,0,0,0"/>
                                        </StackPanel>

                                        <DataGrid Grid.Row="1"
                                                  ItemsSource="{Binding TrussParameters}"
                                                  SelectedItem="{Binding SelectedTrussParameter}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column"
                                                  SelectionMode="Single"
                                                  SelectionUnit="FullRow">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="No." Binding="{Binding ParameterName}" Width="90"/>
                                                <DataGridTextColumn Header="ID" Binding="{Binding TrussId}" Width="70"/>
                                                <DataGridTextColumn Header="Type" Binding="{Binding TrussType}" Width="150"/>
                                                <DataGridTextColumn Header="Coordinate" Binding="{Binding CoordinateDisplay}" Width="170"/>
                                                <DataGridTextColumn Header="Orientation" Binding="{Binding OrientationDisplay}" Width="100"/>
                                                <DataGridTextColumn Header="Colour" Binding="{Binding ColorDisplay}" Width="120"/>
                                                <DataGridTextColumn Header="Spacing" Binding="{Binding TrussSpacingDisplay}" Width="95"/>
                                                <DataGridTextColumn Header="Offset" Binding="{Binding TrussSpacingDirectionDisplay}" Width="120"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Spiral Staircase Inputs" Visibility="{Binding SpiralInputsVisibility}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="145"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <controls:SliderNumberInput Grid.Row="0" Grid.ColumnSpan="2" Label="Centre X" Unit="m" Minimum="-100" Maximum="100" SmallChange="0.1" LargeChange="1" DecimalPlaces="3" Value="{Binding SpiralCentreX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="1" Grid.ColumnSpan="2" Label="Centre Y" Unit="m" Minimum="-100" Maximum="100" SmallChange="0.1" LargeChange="1" DecimalPlaces="3" Value="{Binding SpiralCentreY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="2" Grid.ColumnSpan="2" Label="Base Z" Unit="m" Minimum="-50" Maximum="100" SmallChange="0.1" LargeChange="1" DecimalPlaces="3" Value="{Binding SpiralBaseZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="3" Grid.ColumnSpan="2" Label="Total height" Unit="m" Minimum="0.5" Maximum="20" SmallChange="0.1" LargeChange="1" DecimalPlaces="3" Value="{Binding SpiralTotalHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="4" Grid.ColumnSpan="2" Label="Inner radius" Unit="m" Minimum="0.1" Maximum="10" SmallChange="0.05" LargeChange="0.5" DecimalPlaces="3" Value="{Binding SpiralInnerRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="5" Grid.ColumnSpan="2" Label="Outer radius" Unit="m" Minimum="0.2" Maximum="20" SmallChange="0.05" LargeChange="0.5" DecimalPlaces="3" Value="{Binding SpiralOuterRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="6" Grid.ColumnSpan="2" Label="Number of steps" Unit="nos" Minimum="3" Maximum="120" SmallChange="1" LargeChange="5" IsInteger="True" Value="{Binding SpiralStepCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="7" Grid.ColumnSpan="2" Label="Rotation" Unit="deg" Minimum="30" Maximum="1440" SmallChange="5" LargeChange="45" DecimalPlaces="0" Value="{Binding SpiralTotalRotationDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="8" Grid.ColumnSpan="2" Label="Start angle" Unit="deg" Minimum="-360" Maximum="360" SmallChange="5" LargeChange="45" DecimalPlaces="0" Value="{Binding SpiralStartAngleDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Direction"/>
                                        <ComboBox Grid.Row="9" Grid.Column="1"
                                                  ItemsSource="{Binding SpiralRotationDirections}"
                                                  SelectedItem="{Binding SelectedSpiralRotationDirection}"/>
                                        <CheckBox Grid.Row="10" Grid.Column="1" Content="Create inner stringer" IsChecked="{Binding SpiralCreateInnerStringer}"/>
                                        <CheckBox Grid.Row="11" Grid.Column="1" Content="Create outer stringer" IsChecked="{Binding SpiralCreateOuterStringer}"/>
                                        <CheckBox Grid.Row="12" Grid.Column="1" Content="Create radial tread beams" IsChecked="{Binding SpiralCreateRadialTreadBeams}"/>
                                        <CheckBox Grid.Row="13" Grid.Column="1" Content="Create tread shell plates" IsChecked="{Binding SpiralCreateTreadShellPlates}"/>
                                        <CheckBox Grid.Row="14" Grid.Column="1" Content="Create central column" IsChecked="{Binding SpiralCreateCentralColumn}"/>
                                        <CheckBox Grid.Row="15" Grid.Column="1" Content="Create top landing beam" IsChecked="{Binding SpiralCreateTopLandingBeam}"/>
                                        <CheckBox Grid.Row="16" Grid.Column="1" Content="Create bottom landing beam" IsChecked="{Binding SpiralCreateBottomLandingBeam}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Fish-Belly Truss Inputs" Visibility="{Binding FishBellyInputsVisibility}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="145"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <controls:SliderNumberInput Grid.Row="0" Grid.ColumnSpan="2" Label="Start X" Unit="m" Minimum="-100" Maximum="100" SmallChange="0.1" LargeChange="1" DecimalPlaces="3" Value="{Binding FishStartX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="1" Grid.ColumnSpan="2" Label="Start Y" Unit="m" Minimum="-100" Maximum="100" SmallChange="0.1" LargeChange="1" DecimalPlaces="3" Value="{Binding FishStartY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="2" Grid.ColumnSpan="2" Label="Top chord Z" Unit="m" Minimum="-20" Maximum="100" SmallChange="0.1" LargeChange="1" DecimalPlaces="3" Value="{Binding FishStartZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="3" Grid.ColumnSpan="2" Label="Span length" Unit="m" Minimum="1" Maximum="100" SmallChange="0.1" LargeChange="1" DecimalPlaces="3" Value="{Binding FishSpanLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="4" Grid.ColumnSpan="2" Label="Number of panels" Unit="nos" Minimum="2" Maximum="60" SmallChange="1" LargeChange="5" IsInteger="True" Value="{Binding FishPanelCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="5" Grid.ColumnSpan="2" Label="End depth" Unit="m" Minimum="0.1" Maximum="10" SmallChange="0.05" LargeChange="0.5" DecimalPlaces="3" Value="{Binding FishEndDepth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="6" Grid.ColumnSpan="2" Label="Middle depth" Unit="m" Minimum="0.2" Maximum="20" SmallChange="0.05" LargeChange="0.5" DecimalPlaces="3" Value="{Binding FishMiddleDepth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="7" Grid.ColumnSpan="2" Label="Plan angle" Unit="deg" Minimum="-180" Maximum="180" SmallChange="1" LargeChange="15" DecimalPlaces="0" Value="{Binding FishDirectionAngleDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <controls:SliderNumberInput Grid.Row="8" Grid.ColumnSpan="2" Label="Top chord slope" Unit="deg" Minimum="-30" Maximum="30" SmallChange="0.5" LargeChange="5" DecimalPlaces="1" Value="{Binding FishTopChordSlopeDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bottom shape"/>
                                        <ComboBox Grid.Row="9" Grid.Column="1"
                                                  ItemsSource="{Binding FishBottomChordShapes}"
                                                  SelectedItem="{Binding SelectedFishBottomChordShape}"/>
                                        <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Web pattern"/>
                                        <ComboBox Grid.Row="10" Grid.Column="1"
                                                  ItemsSource="{Binding FishWebPatterns}"
                                                  SelectedItem="{Binding SelectedFishWebPattern}"/>
                                        <CheckBox Grid.Row="11" Grid.Column="1"
                                                  Content="Release moments for truss behaviour"
                                                  IsChecked="{Binding FishReleaseMoments}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Variable Panel Width Truss Inputs" Visibility="{Binding VariablePanelInputsVisibility}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="145"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>

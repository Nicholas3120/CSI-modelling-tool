                                                 Text="{Binding LowerCutHeight, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                 Visibility="{Binding ManualGeometryInputVisibility}"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Upper cut height"
                                                   Visibility="{Binding ManualGeometryInputVisibility}"/>

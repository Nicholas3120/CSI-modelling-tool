                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="Preview mode"
                                                           Style="{StaticResource FieldLabel}"
                                                           Margin="0,7,10,3"/>
                                                <ComboBox DockPanel.Dock="Left"
                                                          ItemsSource="{Binding SectionPreviewModes}"
                                                          SelectedItem="{Binding SelectedSectionPreviewMode}"
                                                          Width="90"
                                                          MinWidth="0"/>
                                            </DockPanel>

                                            <Grid Grid.Row="1">
                                                <controls:EtabsFrame3DPreviewControl Frames="{Binding SectionEditorFrames}"
                                                                                    Frame="{Binding SelectedSectionEditorFrame}"
                                                                                    Visibility="{Binding SectionPreview3DVisibility}"/>
                                                <controls:EtabsFrame2DPreviewControl Frames="{Binding SectionEditorFrames}"
                                                                                    Frame="{Binding SelectedSectionEditorFrame}"
                                                                                    Visibility="{Binding SectionPreview2DVisibility}"/>
                                            </Grid>

                                            <Border VerticalAlignment="Bottom"
                                                    Grid.Row="1"
                                                    Background="#CCFFFFFF"
                                                    BorderBrush="#e2e8f0"
                                                    BorderThickness="1"
                                                    Padding="8"
                                                    Margin="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding SelectedSectionEditorFrame.FrameName, StringFormat=Frame: {0}}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SelectedSectionEditorFrame.CurrentSection, StringFormat=Section: {0}}"
                                                               Foreground="#475569"/>
                                                    <TextBlock Text="{Binding SelectedSectionEditorFrame.LengthM, StringFormat=Length: {0:0.###} m}"
                                                               Foreground="#475569"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </GroupBox>
                                </Grid>
                            </Grid>
                        </GroupBox>

                        <Grid Grid.Row="3" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="380"/>
                            </Grid.ColumnDefinitions>
                            <GroupBox Grid.Column="0" Header="Actions">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Content="Update Sections in ETABS"
                                            Command="{Binding UpdateEtabsFrameSectionsCommand}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"/>

                                    <Border Grid.Column="1"
                                            Width="1"
                                            Background="#cbd5e1"
                                            Margin="0,2,16,2"/>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Update Checked Frame Loads"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,4"/>

                                        <WrapPanel>
                                            <StackPanel Width="175" Margin="0,0,10,0">
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="Pattern"/>
                                                <ComboBox ItemsSource="{Binding LoadPatterns}"
                                                          SelectedItem="{Binding SectionEditorLoadPattern}"
                                                          MinWidth="0"/>
                                            </StackPanel>
                                            <StackPanel Width="160" Margin="0,0,10,0">
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="Input"/>
                                                <ComboBox ItemsSource="{Binding LoadInputTypes}"
                                                          SelectedItem="{Binding SectionEditorLoadInputType}"
                                                          MinWidth="0"/>
                                            </StackPanel>
                                            <StackPanel Width="120" Margin="0,0,10,0">
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding SectionEditorLoadMagnitudeLabel}"/>
                                                <TextBox Text="{Binding SectionEditorLoadMagnitude, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                            </StackPanel>
                                            <StackPanel Width="120"
                                                        Margin="0,0,10,0"
                                                        Visibility="{Binding SectionEditorLoadPanelWidthVisibility}">
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="Panel width"/>
                                                <TextBox Text="{Binding SectionEditorLoadPanelWidth, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                            </StackPanel>
                                        </WrapPanel>

                                        <DockPanel LastChildFill="True" Margin="0,8,0,0">
                                            <Button DockPanel.Dock="Right"
                                                    Content="Update Loads in ETABS"
                                                    Command="{Binding UpdateEtabsFrameLoadsCommand}"
                                                    Margin="8,0,0,0"/>
                                            <CheckBox DockPanel.Dock="Left"
                                                      Content="Replace selected pattern on checked frames"
                                                      IsChecked="{Binding SectionEditorReplaceSelectedPatternLoads}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            <TextBlock Text="{Binding SectionEditorEquivalentLineLoadDisplay}"
                                                       Foreground="#475569"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Grid.Column="2" Header="Warnings">
                                <DataGrid ItemsSource="{Binding SectionEditorMessages}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding SeverityText}" Width="95"/>
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Loads" DataContext="{Binding LoadCaseCombination}">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="190"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="ETABS Connection" Grid.Row="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="380"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="Refresh ETABS Instances"
                                        Command="{Binding RefreshEtabsInstancesCommand}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding EtabsInstances}"
                                          SelectedItem="{Binding SelectedEtabsInstance}"
                                          DisplayMemberPath="DisplayName"/>
                                <Button Grid.Column="2"
                                        Content="Read Load Data"
                                        Command="{Binding ReadEtabsDataCommand}"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding ConnectionStatus, StringFormat=Status: {0}}"
                                               FontWeight="SemiBold"
                                               Foreground="#075985"
                                               Margin="0,0,14,0"/>
                                    <TextBlock Text="{Binding LoadPatterns.Count, StringFormat=Patterns: {0}}"
                                               Foreground="#475569"
                                               Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding LoadCases.Count, StringFormat=Cases: {0}}"
                                               Foreground="#475569"
                                               Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding LoadCombinations.Count, StringFormat=Combos: {0}}"
                                               Foreground="#475569"/>
                                </StackPanel>
                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="4"
                                        Margin="0,8,0,0"
                                        Padding="8,5"
                                        BorderBrush="#bfdbfe"
                                        BorderThickness="1"
                                        Background="#eff6ff">
                                    <DockPanel LastChildFill="True">
                                        <ProgressBar DockPanel.Dock="Left"
                                                     Width="110"
                                                     Height="10"
                                                     IsIndeterminate="True"
                                                     Visibility="{Binding BusyVisibility}"
                                                     Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding OperationStatus}"
                                                   Foreground="#075985"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </GroupBox>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0"/>
                                <ColumnDefinition Width="0"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                                <StackPanel>
                                    <GroupBox Header="Load Pattern">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="155"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Pattern name"/>
                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                     Text="{Binding PatternName, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Pattern type"/>
                                            <ComboBox Grid.Row="1" Grid.Column="1"
                                                      ItemsSource="{Binding PatternTypes}"
                                                      SelectedItem="{Binding SelectedPatternType}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Self weight"/>
                                            <TextBox Grid.Row="2" Grid.Column="1"
                                                     Text="{Binding SelfWeightMultiplier, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>

                                            <WrapPanel Grid.Row="3" Grid.Column="1" Margin="0,8,0,0">
                                                <Button Content="New"
                                                        Command="{Binding NewLoadPatternCommand}"/>
                                                <Button Content="Duplicate"
                                                        Command="{Binding DuplicateLoadPatternCommand}"/>
                                                <Button Content="Apply"
                                                        Command="{Binding SaveLoadPatternCommand}"/>
                                                <Button Content="Mark Delete"
                                                        Command="{Binding DeleteLoadPatternCommand}"/>
                                            </WrapPanel>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="Static Load Case">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="155"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Case name"/>
                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                     Text="{Binding StaticCaseName, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Load pattern"/>
                                            <ComboBox Grid.Row="1" Grid.Column="1"
                                                      ItemsSource="{Binding LoadPatternNames}"
                                                      SelectedItem="{Binding SelectedCaseLoadPattern}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Scale factor"/>
                                            <TextBox Grid.Row="2" Grid.Column="1"
                                                     Text="{Binding StaticCaseScaleFactor, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>

                                            <WrapPanel Grid.Row="3" Grid.Column="1" Margin="0,8,0,0">
                                                <Button Content="New"
                                                        Command="{Binding NewStaticCaseCommand}"/>
                                                <Button Content="Duplicate"
                                                        Command="{Binding DuplicateStaticCaseCommand}"/>
                                                <Button Content="Apply"
                                                        Command="{Binding SaveStaticCaseCommand}"/>
                                                <Button Content="Mark Delete"
                                                        Command="{Binding DeleteStaticCaseCommand}"/>
                                            </WrapPanel>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="Selected Case Items">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="150"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <DataGrid Grid.Row="0"
                                                      ItemsSource="{Binding CaseItems}"
                                                      SelectedItem="{Binding SelectedCaseItem}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      GridLinesVisibility="Horizontal"
                                                      HeadersVisibility="Column">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Load type" Width="95">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding LoadType}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.CaseLoadTypes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                          SelectedItem="{Binding LoadType, UpdateSourceTrigger=PropertyChanged}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Pattern / accel" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.LoadPatternNames, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                          Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                          IsEditable="True"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Scale" Binding="{Binding ScaleFactor, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="80"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                                                <Button Content="Add Item"
                                                        Command="{Binding AddCaseItemCommand}"/>
                                                <Button Content="Remove Item"
                                                        Command="{Binding RemoveCaseItemCommand}"
                                                        CommandParameter="{Binding SelectedCaseItem}"/>
                                                <Button Content="Clear Items"
                                                        Command="{Binding ClearCaseItemsCommand}"/>
                                            </WrapPanel>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="Response Combination">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="155"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="170"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Combo name"/>
                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                     Text="{Binding ComboName, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Combo type"/>
                                            <ComboBox Grid.Row="1" Grid.Column="1"
                                                      ItemsSource="{Binding ComboTypes}"
                                                      SelectedItem="{Binding SelectedComboType}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Source type"/>
                                            <ComboBox Grid.Row="2" Grid.Column="1"
                                                      ItemsSource="{Binding ComboSourceTypes}"
                                                      SelectedItem="{Binding SelectedComboSourceType}"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Source name"/>
                                            <ComboBox Grid.Row="3" Grid.Column="1"
                                                      ItemsSource="{Binding ComboSourceNames}"
                                                      SelectedItem="{Binding SelectedComboSourceName}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Factor"/>
                                            <TextBox Grid.Row="4" Grid.Column="1"
                                                     Text="{Binding ComboItemFactor, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>

                                            <Button Grid.Row="5" Grid.Column="1"
                                                    Content="Add Item"
                                                    Command="{Binding AddComboItemCommand}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,8,8,0"/>

                                            <DataGrid Grid.Row="6" Grid.ColumnSpan="2"
                                                      ItemsSource="{Binding ComboItems}"
                                                      SelectedItem="{Binding SelectedComboItem}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      GridLinesVisibility="Horizontal"
                                                      HeadersVisibility="Column"
                                                      Margin="0,10,0,0">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Source" Width="105">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding SourceType}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.ComboSourceTypes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                          SelectedItem="{Binding SourceType, UpdateSourceTrigger=PropertyChanged}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                                    <DataGridTextColumn Header="Factor" Binding="{Binding Factor, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="85"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <WrapPanel Grid.Row="7" Grid.Column="1" Margin="0,8,0,0">
                                                <Button Content="New"
                                                        Command="{Binding NewComboCommand}"/>
                                                <Button Content="Duplicate"
                                                        Command="{Binding DuplicateComboCommand}"/>
                                                <Button Content="Remove Item"
                                                        Command="{Binding RemoveComboItemCommand}"
                                                        CommandParameter="{Binding SelectedComboItem}"/>
                                                <Button Content="Clear Items"
                                                        Command="{Binding ClearComboItemsCommand}"/>
                                                <Button Content="Apply"
                                                        Command="{Binding SaveComboCommand}"/>
                                                <Button Content="Mark Delete"
                                                        Command="{Binding DeleteComboCommand}"/>
                                            </WrapPanel>

                                            <TextBlock Grid.Row="8" Grid.Column="1"
                                                       Text="{Binding EditorStatus}"
                                                       Style="{StaticResource FieldValue}"/>
                                        </Grid>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>

                            <TabControl Grid.Column="2">
                                <TabItem Header="Patterns">
                                    <DockPanel Margin="0,4,0,0">
                                        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                            <Button Content="New Pattern"
                                                    Command="{Binding NewLoadPatternCommand}"/>
                                            <Button Content="Duplicate Pattern"
                                                    Command="{Binding DuplicateLoadPatternCommand}"/>
                                            <Button Content="Apply Selected Pattern"
                                                    Command="{Binding SaveLoadPatternCommand}"/>
                                            <Button Content="Mark Delete"
                                                    Command="{Binding DeleteLoadPatternCommand}"/>
                                            <Button Content="Delete Marked"
                                                    Command="{Binding DeleteMarkedRowsCommand}"
                                                    ToolTip="Delete all rows marked Deleted in Patterns, Cases, and Combinations."/>
                                        </WrapPanel>
                                        <DataGrid ItemsSource="{Binding LoadPatterns}"
                                                  SelectedItem="{Binding SelectedLoadPattern}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" IsReadOnly="True" Width="75"/>
                                                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                                                <DataGridTemplateColumn Header="Type" Width="190">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding PatternType}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{Binding DataContext.PatternTypes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                      SelectedItem="{Binding PatternType, UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Self weight" Binding="{Binding SelfWeightMultiplier, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="105"/>
                                                <DataGridTextColumn Header="Used by" Binding="{Binding UsedBy}" IsReadOnly="True" Width="180"/>
                                                <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" IsReadOnly="True" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </TabItem>
                                <TabItem Header="Cases">
                                    <Grid Margin="0,4,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="220"/>
                                        </Grid.RowDefinitions>
                                        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                                            <Button Content="New Case"
                                                    Command="{Binding NewStaticCaseCommand}"/>
                                            <Button Content="Duplicate Case"
                                                    Command="{Binding DuplicateStaticCaseCommand}"/>
                                            <Button Content="Apply Selected Case"
                                                    Command="{Binding SaveStaticCaseCommand}"/>
                                            <Button Content="Mark Delete"
                                                    Command="{Binding DeleteStaticCaseCommand}"/>
                                            <Button Content="Delete Marked"
                                                    Command="{Binding DeleteMarkedRowsCommand}"
                                                    ToolTip="Delete all rows marked Deleted in Patterns, Cases, and Combinations."/>
                                        </WrapPanel>
                                        <DataGrid Grid.Row="1"
                                                  ItemsSource="{Binding LoadCases}"
                                                  SelectedItem="{Binding SelectedLoadCase}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" IsReadOnly="True" Width="75"/>
                                                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                                                <DataGridTextColumn Header="Type" Binding="{Binding CaseType}" IsReadOnly="True" Width="130"/>
                                                <DataGridTextColumn Header="Items" Binding="{Binding ItemsSummary}" IsReadOnly="True" Width="*"/>
                                                <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" IsReadOnly="True" Width="180"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <GroupBox Grid.Row="2" Header="Selected Case Loads" Margin="0,10,0,0">
                                            <DockPanel LastChildFill="True">
                                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                                    <Button Content="Add Load"
                                                            Command="{Binding AddTableCaseItemCommand}"
                                                            CommandParameter="{Binding SelectedLoadCase}"/>
                                                    <Button Content="Clear Loads"
                                                            Command="{Binding ClearTableCaseItemsCommand}"
                                                            CommandParameter="{Binding SelectedLoadCase}"/>
                                                    <Button Content="Apply to ETABS"
                                                            Command="{Binding SaveStaticCaseCommand}"/>
                                                </WrapPanel>
                                                <DataGrid ItemsSource="{Binding SelectedLoadCase.Items}"
                                                          AutoGenerateColumns="False"
                                                          CanUserAddRows="False"
                                                          GridLinesVisibility="Horizontal"
                                                          HeadersVisibility="Column">
                                                    <DataGrid.Columns>
                                                        <DataGridTemplateColumn Header="Load type" Width="150">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding LoadType}"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                                <DataTemplate>
                                                                    <ComboBox ItemsSource="{Binding DataContext.CaseLoadTypes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                              SelectedItem="{Binding LoadType, UpdateSourceTrigger=PropertyChanged}"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellEditingTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Header="Pattern / accel" Width="*">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Name}"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                                <DataTemplate>
                                                                    <ComboBox ItemsSource="{Binding DataContext.LoadPatternNames, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                              Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                              IsEditable="True"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellEditingTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Header="Scale factor"
                                                                            Binding="{Binding ScaleFactor, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                                            Width="130"/>
                                                        <DataGridTemplateColumn Header="Action" Width="95">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Button Content="Remove"
                                                                            Command="{Binding DataContext.RemoveTableCaseItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                            CommandParameter="{Binding}"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </DockPanel>
                                        </GroupBox>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Combinations">
                                    <Grid Margin="0,4,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="230"/>
                                        </Grid.RowDefinitions>
                                        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                                            <Button Content="New Combo"
                                                    Command="{Binding NewComboCommand}"/>
                                            <Button Content="Duplicate Combo"
                                                    Command="{Binding DuplicateComboCommand}"/>
                                            <Button Content="Apply Selected Combo"
                                                    Command="{Binding SaveComboCommand}"/>
                                            <Button Content="Mark Delete"
                                                    Command="{Binding DeleteComboCommand}"/>
                                            <Button Content="Delete Marked"
                                                    Command="{Binding DeleteMarkedRowsCommand}"
                                                    ToolTip="Delete all rows marked Deleted in Patterns, Cases, and Combinations."/>
                                        </WrapPanel>
                                        <DataGrid Grid.Row="1"
                                                  ItemsSource="{Binding LoadCombinationFactorMatrix}"
                                                  SelectedItem="{Binding SelectedLoadCombinationMatrixRow}"
                                                  AutoGenerateColumns="True"
                                                  CanUserAddRows="False"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column"/>

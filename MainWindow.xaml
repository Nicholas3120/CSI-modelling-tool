                                                   Visibility="{Binding MidRailSingleElevationVisibility}"/>
                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                 Text="{Binding MidRailElevation, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                 Visibility="{Binding MidRailSingleElevationVisibility}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bottom rail"/>
                                        <CheckBox Grid.Row="3" Grid.Column="1"
                                                  IsChecked="{Binding GenerateBottomRail}"
                                                  VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bottom elevation"
                                                   Visibility="{Binding BottomRailInputVisibility}"/>
                                        <TextBox Grid.Row="4" Grid.Column="1"
                                                 Text="{Binding BottomRailElevation, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                 Visibility="{Binding BottomRailInputVisibility}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Assignments">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="155"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Post section"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1"
                                                  ItemsSource="{Binding FrameSections}"
                                                  SelectedItem="{Binding SelectedPostSection}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Top rail section"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  ItemsSource="{Binding FrameSections}"
                                                  SelectedItem="{Binding SelectedTopRailSection}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Mid rail section"
                                                   Visibility="{Binding MidRailInputVisibility}"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding FrameSections}"
                                                  SelectedItem="{Binding SelectedMidRailSection}"
                                                  Visibility="{Binding MidRailInputVisibility}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bottom rail section"
                                                   Visibility="{Binding BottomRailInputVisibility}"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1"
                                                  ItemsSource="{Binding FrameSections}"
                                                  SelectedItem="{Binding SelectedBottomRailSection}"
                                                  Visibility="{Binding BottomRailInputVisibility}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Supports and Loads">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="155"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Base condition"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1"
                                                  ItemsSource="{Binding BaseRestraintTypes}"
                                                  SelectedItem="{Binding SelectedBaseRestraint}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Apply load"/>
                                        <CheckBox Grid.Row="1" Grid.Column="1"
                                                  IsChecked="{Binding ApplyTopRailLoad}"
                                                  VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Load type"
                                                   Visibility="{Binding LoadInputVisibility}"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding LoadTypes}"
                                                  SelectedItem="{Binding SelectedLoadType}"
                                                  Visibility="{Binding LoadInputVisibility}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Load pattern"
                                                   Visibility="{Binding LoadInputVisibility}"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1"
                                                  ItemsSource="{Binding LoadPatterns}"
                                                  SelectedItem="{Binding SelectedLoadPattern}"
                                                  Visibility="{Binding LoadInputVisibility}"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Load direction"
                                                   Visibility="{Binding LoadInputVisibility}"/>
                                        <ComboBox Grid.Row="4" Grid.Column="1"
                                                  ItemsSource="{Binding LoadDirections}"
                                                  SelectedItem="{Binding SelectedLoadDirection}"
                                                  Visibility="{Binding LoadInputVisibility}"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Apply to"
                                                   Visibility="{Binding LineLoadInputVisibility}"/>
                                        <ComboBox Grid.Row="5" Grid.Column="1"
                                                  ItemsSource="{Binding LoadTargets}"
                                                  SelectedItem="{Binding SelectedLoadTarget}"
                                                  Visibility="{Binding LineLoadInputVisibility}"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Line load kN/m"
                                                   Visibility="{Binding LineLoadInputVisibility}"/>
                                        <TextBox Grid.Row="6" Grid.Column="1"
                                                 Text="{Binding HorizontalLoadKnPerM, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                 Visibility="{Binding LineLoadInputVisibility}"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Point height"
                                                   Visibility="{Binding PointLoadInputVisibility}"/>
                                        <TextBox Grid.Row="7" Grid.Column="1"
                                                 Text="{Binding PointLoadHeight, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                 Visibility="{Binding PointLoadInputVisibility}"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Point load kN"
                                                   Visibility="{Binding PointLoadInputVisibility}"/>
                                        <TextBox Grid.Row="8" Grid.Column="1"
                                                 Text="{Binding HorizontalPointLoadKn, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                 Visibility="{Binding PointLoadInputVisibility}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Actions">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="155"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Update mode"/>
                                        <CheckBox Grid.Row="0" Grid.Column="1"
                                                  Content="Update existing railing group"
                                                  IsChecked="{Binding UpdateExistingGroup}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="Validate" Command="{Binding ValidateRailingCommand}"/>
                                            <Button Content="Draw/Update Railing in ETABS" Command="{Binding DrawRailingCommand}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{Binding RailingStatus}"
                                                   Style="{StaticResource FieldValue}"/>
                                    </Grid>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>

                        <GroupBox Grid.Column="2" Header="2D Railing Preview (ETABS X-Z Plane)">
                            <controls:Railing2DPreviewControl Model="{Binding CurrentRailingModel}"
                                                              MinHeight="420"/>
                        </GroupBox>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <GroupBox Header="Warnings">
                            <DataGrid ItemsSource="{Binding Messages}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Severity" Binding="{Binding SeverityText}" Width="95"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Model Compare" DataContext="{Binding ModelCompare}">
                <views:ModelCompareView/>
            </TabItem>
            <TabItem Header="IFC Structural Import" DataContext="{Binding IfcStructuralImport}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="IFC File" Grid.Row="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="85"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource FieldLabel}"
                                       Text="IFC file"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding IfcFilePath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Command="{Binding BrowseIfcCommand}"/>
                            <Button Grid.Column="3"
                                    Content="Run Import"
                                    Command="{Binding RunImportCommand}"/>
                            <Button Grid.Column="4"
                                    Content="Cancel"
                                    Command="{Binding CancelImportCommand}"/>
                            <StackPanel Grid.Column="5"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="6,0,0,0"
                                        Visibility="{Binding BusyVisibility}">
                                <ProgressBar Width="120"
                                             Height="12"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding ProgressPercent, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ProgressText}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#475569"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Import Options" Grid.Row="1">
                        <WrapPanel>
                            <CheckBox Content="Include beams"
                                      IsChecked="{Binding IncludeBeams}"
                                      Margin="0,0,18,4"
                                      VerticalAlignment="Center"/>
                            <CheckBox Content="Include columns"
                                      IsChecked="{Binding IncludeColumns}"
                                      Margin="0,0,18,4"
                                      VerticalAlignment="Center"/>
                            <CheckBox Content="Include slabs"
                                      IsChecked="{Binding IncludeSlabs}"
                                      Margin="0,0,18,4"
                                      VerticalAlignment="Center"/>
                            <CheckBox Content="Include walls"
                                      IsChecked="{Binding IncludeWalls}"
                                      Margin="0,0,18,4"
                                      VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource FieldLabel}"
                                       Text="Node snap (mm)"
                                       Margin="0,0,6,0"/>
                            <TextBox Width="90"
                                     Text="{Binding NodeSnapToleranceMm, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                     Margin="0,0,18,0"/>
                            <CheckBox Content="Reset coordinate origin"
                                      IsChecked="{Binding ResetCoordinateOrigin}"
                                      Margin="0,0,18,0"
                                      VerticalAlignment="Center"/>
                            <CheckBox Content="Connect frames (beam→column)"
                                      IsChecked="{Binding ConnectFrames}"
                                      Margin="0,0,18,0"
                                      VerticalAlignment="Center"/>
                            <CheckBox Content="Recover mesh-only members"
                                      IsChecked="{Binding RecoverMeshGeometry}"
                                      Margin="0,0,18,0"
                                      VerticalAlignment="Center"/>
                            <CheckBox Content="Structural walls only (exclude partitions)"
                                      IsChecked="{Binding StructuralWallsOnly}"
                                      VerticalAlignment="Center"/>
                        </WrapPanel>
                    </GroupBox>

                    <GroupBox Header="Result Summary" Grid.Row="2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <UniformGrid Grid.Row="0"
                                         Grid.Column="0"
                                         Columns="3">
                                <TextBlock Text="{Binding ImportedCount, StringFormat=Imported: {0}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SkippedCount, StringFormat=Skipped: {0}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding WarningCount, StringFormat=Warnings: {0}}"
                                           FontWeight="SemiBold"/>
                            </UniformGrid>
                            <StackPanel Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal">
                                <Button Content="Export JSON"
                                        Command="{Binding ExportJsonCommand}"/>
                                <Button Content="Open JSON"
                                        Command="{Binding OpenJsonCommand}"/>
                                <Button Content="Export Report"
                                        Command="{Binding ExportReportCommand}"/>
                                <Button Content="Open Report"
                                        Command="{Binding OpenReportCommand}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding OperationStatus}"
                                       Foreground="#475569"
                                       Margin="0,8,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </GroupBox>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Warnings" Grid.Column="0">
                            <DataGrid ItemsSource="{Binding Warnings}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="85"/>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="105"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding SourceName}" Width="150"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Header="Skipped Elements" Grid.Column="2">
                            <DataGrid ItemsSource="{Binding SkippedElements}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="IFC Type" Binding="{Binding IfcType}" Width="95"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding SourceName}" Width="150"/>
                                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>

                    <GroupBox Header="ETABS Export" Grid.Row="4">
                        <Grid MinHeight="130">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="360"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="Refresh ETABS Instances"
                                    Command="{Binding RefreshEtabsInstancesCommand}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding EtabsInstances}"
                                      SelectedItem="{Binding SelectedEtabsInstance}"
                                      DisplayMemberPath="DisplayName"/>
                            <Button Grid.Column="2"
                                    Content="Export to ETABS"
                                    Command="{Binding ExportToEtabsCommand}"/>
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0"
                                        Visibility="{Binding BusyVisibility}">
                                <ProgressBar Width="120"
                                             Height="12"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding ProgressPercent, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ProgressText}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#475569"/>
                            </StackPanel>
                            <WrapPanel Grid.Row="1"
                                       Grid.ColumnSpan="4"
                                       Margin="0,8,0,0">
                                <CheckBox Content="Export frames"
                                          IsChecked="{Binding ExportFramesToEtabs}"
                                          Margin="0,0,18,4"
                                          VerticalAlignment="Center"/>
                                <CheckBox Content="Export slabs"
                                          IsChecked="{Binding ExportSlabsToEtabs}"
                                          Margin="0,0,18,4"
                                          VerticalAlignment="Center"/>
                                <CheckBox Content="Export walls"
                                          IsChecked="{Binding ExportWallsToEtabs}"
                                          Margin="0,0,18,4"
                                          VerticalAlignment="Center"/>
                                <Separator Margin="0,0,18,0"/>
                                <CheckBox Content="Export medium confidence"
                                          IsChecked="{Binding ExportMediumConfidenceToEtabs}"
                                          Margin="0,0,18,4"
                                          VerticalAlignment="Center"/>
                                <CheckBox Content="Use default section for unknown"
                                          IsChecked="{Binding UseDefaultSectionForUnknown}"
                                          Margin="0,0,18,0"
                                          VerticalAlignment="Center"/>
                                <CheckBox Content="Use default material for unknown"
                                          IsChecked="{Binding UseDefaultMaterialForUnknown}"
                                          VerticalAlignment="Center"/>
                            </WrapPanel>
                            <TextBlock Grid.Row="2"
                                       Grid.ColumnSpan="4"
                                       Text="{Binding EtabsExportStatus}"
                                       Foreground="#475569"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

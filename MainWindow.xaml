                                                   Visibility="{Binding PartialGeometryInputVisibility}"/>
                                        <TextBox Grid.Row="8" Grid.Column="1"
                                                 Text="{Binding PartialDomeHeight, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                 Visibility="{Binding PartialGeometryInputVisibility}"/>

                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Ring spacing"
                                                   Visibility="{Binding ManualGeometryInputVisibility}"/>
                                        <ComboBox Grid.Row="9" Grid.Column="1"
                                                  ItemsSource="{Binding RingSpacingModes}"
                                                  SelectedItem="{Binding SelectedRingSpacingMode}"
                                                  Visibility="{Binding ManualGeometryInputVisibility}"/>

                                        <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Top radius"
                                                   Visibility="{Binding PartialGeometryInputVisibility}"/>
                                        <TextBox Grid.Row="10" Grid.Column="1"
                                                 Text="{Binding CrownRingRadius, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"
                                                 Visibility="{Binding PartialGeometryInputVisibility}"/>

                                        <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Rings"/>
                                        <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding RingCount, UpdateSourceTrigger=LostFocus}"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Segments"/>
                                        <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding SegmentCount, UpdateSourceTrigger=LostFocus}"/>

                                        <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Full 360"/>
                                        <CheckBox Grid.Row="13" Grid.Column="1"
                                                  IsChecked="{Binding Full360}"
                                                  VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="14" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Start angle"/>
                                        <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding StartAngleDeg, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>

                                        <TextBlock Grid.Row="15" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="End angle"/>
                                        <TextBox Grid.Row="15" Grid.Column="1" Text="{Binding EndAngleDeg, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>

                                        <TextBlock Grid.Row="16" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Shell mesh"/>
                                        <ComboBox Grid.Row="16" Grid.Column="1"
                                                  ItemsSource="{Binding ShellMeshTypes}"
                                                  SelectedItem="{Binding SelectedShellMeshType}"/>

                                        <TextBlock Grid.Row="17" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Generated"/>
                                        <TextBlock Grid.Row="17" Grid.Column="1" Style="{StaticResource FieldValue}" Text="{Binding GeneratedDomeCountDisplay}"/>

                                        <TextBlock Grid.Row="18" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Group"/>
                                        <TextBlock Grid.Row="18" Grid.Column="1" Style="{StaticResource FieldValue}" Text="{Binding DomeGroupDisplay}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Elements">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Shell panels"/>
                                        <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding GenerateShellPanels}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Ring beams"/>
                                        <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding GenerateRingFrames}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Radial ribs"/>
                                        <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding GenerateRadialFrames}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Diagonals"/>
                                        <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding GenerateDiagonalFrames}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Base ring"/>
                                        <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding GenerateBaseRing}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Crown ring"/>
                                        <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding GenerateCrownRing}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Base supports"/>
                                        <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding GenerateSupportsAtBase}" VerticalAlignment="Center"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Assignments">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Shell property"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ShellProperties}" SelectedItem="{Binding SelectedShellProperty}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Ring beam section"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding FrameSections}" SelectedItem="{Binding SelectedRingSection}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Radial rib section"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding FrameSections}" SelectedItem="{Binding SelectedRadialSection}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Diagonal section"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding FrameSections}" SelectedItem="{Binding SelectedDiagonalSection}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Base ring section"/>
                                        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding FrameSections}" SelectedItem="{Binding SelectedBaseRingSection}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Crown ring section"/>
                                        <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding FrameSections}" SelectedItem="{Binding SelectedCrownRingSection}"/>
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Load pattern"/>
                                        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding LoadPatterns}" SelectedItem="{Binding SelectedLoadPattern}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Actions">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Update mode"/>
                                        <CheckBox Grid.Row="0" Grid.Column="1"
                                                  Content="Update existing dome group"
                                                  IsChecked="{Binding UpdateExistingGroup}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="Validate" Command="{Binding ValidateDomeCommand}"/>
                                            <Button Content="Draw/Update Dome in ETABS" Command="{Binding DrawDomeCommand}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{Binding DomeStatus}"
                                                   Style="{StaticResource FieldValue}"/>
                                    </Grid>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.9*"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="1.1*"/>
                            </Grid.RowDefinitions>

                            <GroupBox Grid.Row="0" Header="2D Section Preview">
                                <controls:DomeSectionPreviewControl Model="{Binding CurrentDomeModel}"
                                                                    MinHeight="220"/>
                            </GroupBox>

                            <GroupBox Grid.Row="2" Header="3D Dome Preview">
                                <controls:Dome3DPreviewControl Model="{Binding CurrentDomeModel}"
                                                              MinHeight="280"/>
                            </GroupBox>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <GroupBox Header="Warnings">
                            <DataGrid ItemsSource="{Binding Messages}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Severity" Binding="{Binding SeverityText}" Width="95"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Plate Girder" DataContext="{Binding PlateGirder}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="185"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="ETABS Connection" Grid.Row="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Refresh ETABS Instances" Command="{Binding RefreshEtabsInstancesCommand}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding EtabsInstances}"
                                      SelectedItem="{Binding SelectedEtabsInstance}"
                                      DisplayMemberPath="DisplayName"/>
                            <Button Grid.Column="2" Content="Read ETABS Data" Command="{Binding ReadEtabsDataCommand}"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding ConnectionStatus, StringFormat=Status: {0}}"
                                       FontWeight="SemiBold"
                                       Foreground="#075985"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </GroupBox>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <GroupBox Header="Geometry">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="155"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Girder ID"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PlateGirderId, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Origin"/>
                                        <Grid Grid.Row="1" Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="52"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="X" Style="{StaticResource FieldLabel}" Margin="0,7,4,3"/>
                                            <TextBox Grid.Column="1" MinWidth="0" Text="{Binding OriginX, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                            <TextBlock Grid.Column="2" Text="Y" Style="{StaticResource FieldLabel}" Margin="8,7,4,3"/>
                                            <TextBox Grid.Column="3" MinWidth="0" Text="{Binding OriginY, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                            <TextBlock Grid.Column="4" Text="Z" Style="{StaticResource FieldLabel}" Margin="8,7,4,3"/>
                                            <TextBox Grid.Column="5" MinWidth="0" Text="{Binding OriginZ, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                        </Grid>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Length m"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Length, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Web depth m"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Depth, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Flange width m"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding FlangeWidth, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Top flange"/>
                                        <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding GenerateTopFlange}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bottom flange"/>
                                        <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding GenerateBottomFlange}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Length divisions"/>
                                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding LengthDivisions, UpdateSourceTrigger=LostFocus}"/>
                                        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Depth divisions"/>
                                        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding DepthDivisions, UpdateSourceTrigger=LostFocus}"/>
                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Generated"/>
                                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource FieldValue}" Text="{Binding GeneratedCountDisplay}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Opening And Stiffeners">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                            <CheckBox Content="Web openings" IsChecked="{Binding HasWebOpening}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Button Content="Add Opening" Command="{Binding AddOpeningCommand}"/>
                                            <Button Content="Remove Opening" Command="{Binding RemoveOpeningCommand}"/>
                                            <TextBlock Text="{Binding GroupDisplay, StringFormat=Group: {0}}" Style="{StaticResource FieldValue}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <DataGrid ItemsSource="{Binding Openings}"
                                                  SelectedItem="{Binding SelectedOpening}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  MinHeight="190"
                                                  IsEnabled="{Binding HasWebOpening}"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID" Binding="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="54"/>
                                                <DataGridTextColumn Header="X" Binding="{Binding CenterX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="54"/>
                                                <DataGridTextColumn Header="Z" Binding="{Binding CenterZ, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="54"/>
                                                <DataGridTextColumn Header="W" Binding="{Binding Width, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="54"/>
                                                <DataGridTextColumn Header="H" Binding="{Binding Height, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="54"/>
                                                <DataGridCheckBoxColumn Header="Stiff." Binding="{Binding Strengthen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="52"/>
                                                <DataGridTextColumn Header="Out." Binding="{Binding StiffenerOutstand, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="55"/>
                                                <DataGridTextColumn Header="Ext." Binding="{Binding StiffenerExtension, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=0.###}" Width="55"/>
                                                <DataGridCheckBoxColumn Header="Top" Binding="{Binding StrengthenTop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="45"/>
                                                <DataGridCheckBoxColumn Header="Bot" Binding="{Binding StrengthenBottom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="45"/>
                                                <DataGridCheckBoxColumn Header="L" Binding="{Binding StrengthenLeft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                                                <DataGridCheckBoxColumn Header="R" Binding="{Binding StrengthenRight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </GroupBox>

                                <GroupBox Header="Shell Properties And Load">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="155"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Web shell"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ShellProperties}" SelectedItem="{Binding SelectedWebShellProperty}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Flange shell"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding ShellProperties}" SelectedItem="{Binding SelectedFlangeShellProperty}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Stiffener shell"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding ShellProperties}" SelectedItem="{Binding SelectedStiffenerShellProperty}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Apply UDL"/>
                                        <CheckBox Grid.Row="3" Grid.Column="1" Content="Top flange shell area" IsChecked="{Binding ApplyTopFlangeAreaLoad}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Load pattern"/>
                                        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding LoadPatterns}" SelectedItem="{Binding SelectedLoadPattern}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="UDL kN/m"/>
                                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding AnalysisUniformLoadKnPerM, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource FieldValue}" Text="{Binding AreaLoadDisplay}"/>
                                        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="Validate" Command="{Binding ValidateCommand}"/>
                                            <Button Content="Send to ETABS" Command="{Binding DrawToEtabsCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.7*"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="0.95*"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="0.9*"/>
                            </Grid.RowDefinitions>
                            <GroupBox Grid.Row="0" Header="2D Quad Mesh Preview">
                                <controls:PlateGirder2DPreviewControl Model="{Binding CurrentModel}" MinHeight="210"/>
                            </GroupBox>
                            <GroupBox Grid.Row="2" Header="3D Shell Preview">
                                <controls:PlateGirder3DPreviewControl Model="{Binding CurrentModel}" MinHeight="260"/>
                            </GroupBox>
                            <GroupBox Grid.Row="4" Header="Capacity / Deflection Stations">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding AnalysisSummaryDisplay}" FontWeight="SemiBold" Margin="0,0,16,0"/>
                                        <TextBlock Text="{Binding DeflectionDisplay}" Margin="0,0,16,0"/>
                                        <TextBlock Text="{Binding UtilizationDisplay}"/>
                                    </StackPanel>
                                    <Expander Grid.Row="1" Header="Calculation basis" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding PlateGirderCalculationNotes}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#475569"
                                                   Margin="0,4,0,4"/>
                                    </Expander>
                                    <DataGrid Grid.Row="2"
                                              ItemsSource="{Binding SectionResults}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="x m" Binding="{Binding X, StringFormat=0.##}" Width="64"/>
                                            <DataGridTextColumn Header="I m4" Binding="{Binding InertiaY, StringFormat=0.000000}" Width="90"/>
                                            <DataGridTextColumn Header="Cls" Binding="{Binding SectionClass}" Width="42"/>
                                            <DataGridTextColumn Header="FCls" Binding="{Binding FlangeClass}" Width="46"/>
                                            <DataGridTextColumn Header="WCls" Binding="{Binding WebClass}" Width="46"/>
                                            <DataGridTextColumn Header="Mcap kNm" Binding="{Binding MomentCapacityKnM, StringFormat=0.##}" Width="90"/>
                                            <DataGridTextColumn Header="M kNm" Binding="{Binding DemandMomentKnM, StringFormat=0.##}" Width="80"/>
                                            <DataGridTextColumn Header="M Util" Binding="{Binding Utilization, StringFormat=0.###}" Width="70"/>
                                            <DataGridTextColumn Header="Vcap kN" Binding="{Binding ShearCapacityKn, StringFormat=0.##}" Width="80"/>
                                            <DataGridTextColumn Header="V kN" Binding="{Binding DemandShearKn, StringFormat=0.##}" Width="70"/>
                                            <DataGridTextColumn Header="V Util" Binding="{Binding ShearUtilization, StringFormat=0.###}" Width="70"/>
                                            <DataGridTextColumn Header="Defl mm" Binding="{Binding DeflectionMm, StringFormat=0.##}" Width="80"/>
                                            <DataGridTextColumn Header="Basis" Binding="{Binding MomentCapacityBasis}" Width="130"/>
                                            <DataGridCheckBoxColumn Header="Opening" Binding="{Binding WithinOpening}" Width="70"/>
                                            <DataGridCheckBoxColumn Header="Stiff." Binding="{Binding HasStiffener}" Width="58"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">

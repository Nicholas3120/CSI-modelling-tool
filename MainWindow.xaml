                                <TextBlock Grid.Column="3" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="#075985"
                                           Text="{Binding Sap2000ConnectionStatus, StringFormat=Status: {0}}"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>


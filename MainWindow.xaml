                                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding UnitWeightKnPerM3, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
                                                <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource FieldLabel}" Text="Thermal / C"/>
                                                <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding ThermalExpansion, UpdateSourceTrigger=LostFocus, StringFormat=0.########}"/>

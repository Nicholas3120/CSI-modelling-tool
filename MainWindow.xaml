                                            <TextBlock Grid.Column="2" Text="Y" Style="{StaticResource FieldLabel}" Margin="8,7,4,3"/>
                                            <TextBox Grid.Column="3" MinWidth="0" Text="{Binding BaseCenterY, UpdateSourceTrigger=LostFocus, StringFormat=0.###}"/>
